
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Leads: public create only
    match /leads/{leadId} {
      allow read, update, delete: if request.auth != null && false;
      allow create: if true;
    }

    // Certificates: public read (for verification), write protected by session cookie (checked server-side)
    match /certificates/{certId} {
      allow read: if true;
      allow write: if true; // Server-side admin session validates access; tighten with Firebase Auth later
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
